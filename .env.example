# ─── CargoMap tile provider ───────────────────────────────────────────────────
# By default CargoMap uses OpenStreetMap tiles (no key required).
# Set VITE_MAPBOX_TOKEN to switch to Mapbox raster tiles for a higher-quality
# map look (recommended once you have a token).
#
# Where to get a token: https://account.mapbox.com/
# Then copy this file to .env.local and uncomment the line below:
# VITE_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# Reserved for a future Google Maps JS SDK swap. CargoMap does not consume this
# variable today (Leaflet/OSM is the default; Mapbox is the documented swap).
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key_here
